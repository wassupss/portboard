{
  "name": "portboard",
  "productName": "Portboard",
  "version": "0.1.1",
  "description": "Menu-bar dashboard for macOS — see, start and stop your local dev servers and Docker containers, all by port.",
  "main": "build/electron/main.js",
  "author": "wassupss",
  "license": "MIT",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.wassupss.portboard",
    "productName": "Portboard",
    "directories": { "buildResources": "build-resources" },
    "files": ["build/**", "package.json"],
    "publish": [{ "provider": "github", "owner": "wassupss", "repo": "portboard", "releaseType": "release" }],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.png",
      "target": ["dmg", "zip"]
    }
  }
}
